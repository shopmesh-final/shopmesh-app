# ─── Frontend Environment ──────────────────────────────────────────────────

# For local development (docker compose), point directly at each service
REACT_APP_AUTH_SERVICE_URL=http://localhost:3001/api/auth
REACT_APP_PRODUCT_SERVICE_URL=http://localhost:3002/api/products
REACT_APP_ORDER_SERVICE_URL=http://localhost:3003/api/orders

# For AWS deployment, set the internal ALB URL here.
# Nginx will proxy /api/* routes to this URL.
# Leave empty for local dev.
REACT_APP_INTERNAL_ALB_URL=

# Runtime nginx variable (injected at container startup via envsubst)
INTERNAL_ALB_URL=http://internal-alb.example.com
