# ─── Product Service Environment ──────────────────────────────────────────

PORT=3002
NODE_ENV=development

# Local Development Mode
LOCAL_MODE=true

# AWS (only required when LOCAL_MODE=false)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# DynamoDB
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
DYNAMODB_PRODUCTS_TABLE=shopmesh-products

# JWT (only required when LOCAL_MODE=true; otherwise loaded from Secrets Manager)
JWT_SECRET=local-dev-jwt-secret-change-in-production

# SNS Topic ARNs (only used when LOCAL_MODE=false)
SNS_ORDERS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:shopmesh-orders
SNS_ALERTS_TOPIC_ARN=arn:aws:sns:us-east-1:ACCOUNT_ID:shopmesh-alerts

# S3 (only used when LOCAL_MODE=false)
S3_PRODUCT_IMAGES_BUCKET=shopmesh-product-images

# Auth service URL (for inter-service calls)
AUTH_SERVICE_URL=http://auth-service:3001
